---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"lua { x = vec2.x.y().y; }\", |p| p.lua_block())"
---
LUA_CHUNK_EXPR: 0..25 
  LUA_KW: 0..3 "lua"
  WHITESPACE: 3..4 
  L_BRACE: 4..5 "{"
  WHITESPACE: 5..6 
  LUA_STMT_EXPR: 6..23 
    LUA_MULTI_EXPR: 6..7 
      LUA_LIT_EXPR: 6..7 
        IDENT: 6..7 "x"
    WHITESPACE: 7..8 
    EQ: 8..9 "="
    WHITESPACE: 9..10 
    LUA_MULTI_EXPR: 10..22 
      LUA_FIELD_ACCESS_EXPR: 10..22 
        LUA_CALL_EXPR: 10..20 
          LUA_FIELD_ACCESS_EXPR: 10..18 
            LUA_FIELD_ACCESS_EXPR: 10..16 
              LUA_LIT_EXPR: 10..14 
                IDENT: 10..14 "vec2"
              DOT: 14..15 "."
              LUA_NAME: 15..16 
                IDENT: 15..16 "x"
            DOT: 16..17 "."
            LUA_NAME: 17..18 
              IDENT: 17..18 "y"
          LUA_ARG_LIST: 18..20 
            L_PAREN: 18..19 "("
            R_PAREN: 19..20 ")"
        DOT: 20..21 "."
        LUA_NAME: 21..22 
          IDENT: 21..22 "y"
    SEMI: 22..23 ";"
  WHITESPACE: 23..24 
  R_BRACE: 24..25 "}"
