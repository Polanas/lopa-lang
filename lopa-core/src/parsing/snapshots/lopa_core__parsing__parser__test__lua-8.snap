---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"lua { x = vec2.x.y; }\", |p| p.lua_block())"
---
LUA_BLOCK_EXPR: 0..21 
  LUA_KW: 0..3 "lua"
  WHITESPACE: 3..4 
  L_BRACE: 4..5 "{"
  WHITESPACE: 5..6 
  LUA_STMT_EXPR: 6..20 
    LUA_PREFIX_MULTI_EXPR: 6..8 
      LUA_LIT_EXPR: 6..8 
        IDENT: 6..7 "x"
        WHITESPACE: 7..8 
    EQ: 8..9 "="
    WHITESPACE: 9..10 
    LUA_MULTI_EXPR: 10..18 
      LUA_FIELD_ACCESS_EXPR: 10..18 
        LUA_FIELD_ACCESS_EXPR: 10..16 
          LUA_LIT_EXPR: 10..14 
            IDENT: 10..14 "vec2"
          DOT: 14..15 "."
          LUA_NAME: 15..16 
            IDENT: 15..16 "x"
        DOT: 16..17 "."
        LUA_NAME: 17..18 
          IDENT: 17..18 "y"
    SEMI: 18..19 ";"
    WHITESPACE: 19..20 
  R_BRACE: 20..21 "}"
