---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"if !true {} else {}\", |p| p.expr())"
---
IF_EXPR: 0..19 
  IF_KW: 0..2 "if"
  WHITESPACE: 2..3 
  UNARY_EXPR: 3..8 
    BANG: 3..4 "!"
    LIT_EXPR: 4..8 
      TRUE_KW: 4..8 "true"
  WHITESPACE: 8..9 
  BLOCK_EXPR: 9..11 
    L_BRACE: 9..10 "{"
    R_BRACE: 10..11 "}"
  WHITESPACE: 11..12 
  ELSE_KW: 12..16 "else"
  WHITESPACE: 16..17 
  BLOCK_EXPR: 17..19 
    L_BRACE: 17..18 "{"
    R_BRACE: 18..19 "}"
