---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"1+1*3/4%3\", |p| p.expr())"
---
BINARY_EXPR: 0..9 
  LIT_EXPR: 0..1 
    INT: 0..1 "1"
  PLUS: 1..2 "+"
  BINARY_EXPR: 2..9 
    BINARY_EXPR: 2..7 
      BINARY_EXPR: 2..5 
        LIT_EXPR: 2..3 
          INT: 2..3 "1"
        STAR: 3..4 "*"
        LIT_EXPR: 4..5 
          INT: 4..5 "3"
      SLASH: 5..6 "/"
      LIT_EXPR: 6..7 
        INT: 6..7 "4"
    PERCENT: 7..8 "%"
    LIT_EXPR: 8..9 
      INT: 8..9 "3"
