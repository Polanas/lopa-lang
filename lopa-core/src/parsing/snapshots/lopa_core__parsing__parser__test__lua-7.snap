---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"lua { local string = [[ hello there ]]; }\", |p| p.lua_block())"
---
LUA_BLOCK_EXPR: 0..41 
  LUA_KW: 0..3 "lua"
  WHITESPACE: 3..4 
  L_BRACE: 4..5 "{"
  WHITESPACE: 5..6 
  LUA_LOCAL_STMT: 6..40 
    IDENT: 6..11 "local"
    WHITESPACE: 11..12 
    LUA_NAME: 12..19 
      IDENT: 12..18 "string"
      WHITESPACE: 18..19 
    EQ: 19..20 "="
    WHITESPACE: 20..21 
    LUA_MULTI_EXPR: 21..38 
      LUA_LIT_EXPR: 21..38 
        BRACKET_STRING: 21..38 "[[ hello there ]]"
    SEMI: 38..39 ";"
    WHITESPACE: 39..40 
  R_BRACE: 40..41 "}"
