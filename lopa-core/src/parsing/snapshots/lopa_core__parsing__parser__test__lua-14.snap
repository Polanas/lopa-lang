---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"lua { break; }\", |p| p.lua_block())"
---
LUA_CHUNK_EXPR: 0..14 
  LUA_KW: 0..3 "lua"
  WHITESPACE: 3..4 
  L_BRACE: 4..5 "{"
  WHITESPACE: 5..6 
  LUA_BREAK_STMT: 6..12 
    BREAK_KW: 6..11 "break"
    SEMI: 11..12 ";"
  WHITESPACE: 12..13 
  R_BRACE: 13..14 "}"
