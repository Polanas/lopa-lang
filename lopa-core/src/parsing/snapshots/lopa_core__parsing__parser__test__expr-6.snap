---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"if not true {} else {}\", |p| p.expr())"
---
IF_EXPR: 0..22 
  IF_KW: 0..2 "if"
  WHITESPACE: 2..3 
  UNARY_EXPR: 3..12 
    NOT_KW: 3..6 "not"
    WHITESPACE: 6..7 
    LIT_EXPR: 7..12 
      TRUE_KW: 7..11 "true"
      WHITESPACE: 11..12 
  BLOCK_EXPR: 12..15 
    L_BRACE: 12..13 "{"
    R_BRACE: 13..14 "}"
    WHITESPACE: 14..15 
  ELSE_KW: 15..19 "else"
  WHITESPACE: 19..20 
  BLOCK_EXPR: 20..22 
    L_BRACE: 20..21 "{"
    R_BRACE: 21..22 "}"
