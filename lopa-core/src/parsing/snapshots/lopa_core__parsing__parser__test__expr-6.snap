---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"if not true {} else {}\", |p| p.expr())"
---
IF_EXPR: 0..22
  if: 0..2
  WHITESPACE: 2..3
  UNARY_EXPR: 3..12
    not: 3..6
    WHITESPACE: 6..7
    LIT_EXPR: 7..12
      true: 7..11
      WHITESPACE: 11..12
  BLOCK_EXPR: 12..15
    {: 12..13
    }: 13..14
    WHITESPACE: 14..15
  else: 15..19
  WHITESPACE: 19..20
  BLOCK_EXPR: 20..22
    {: 20..21
    }: 21..22
