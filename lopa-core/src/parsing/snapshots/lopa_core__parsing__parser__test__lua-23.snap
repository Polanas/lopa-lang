    LUA_NAME: 28..30 
      IDENT: 28..29 "x"
      WHITESPACE: 29..30 
    EQ: 30..31 "="
    WHITESPACE: 31..32 
    LUA_MULTI_EXPR: 32..46 
      LUA_FUNCTION_EXPR: 32..46 
        IDENT: 32..40 "function"
        LUA_PARAM_LIST: 40..43 
          L_PAREN: 40..41 "("
          R_PAREN: 41..42 ")"
          WHITESPACE: 42..43 
        LUA_BLOCK_STMT: 43..46 
          IDENT: 43..46 "end"
    SEMI: 46..47 ";"
