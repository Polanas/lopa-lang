---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"lua{1+2}\", |p| p.lua_block())"
---
LUA_BLOCK_EXPR: 0..8 
  LUA_KW: 0..3 "lua"
  L_BRACE: 3..4 "{"
  LUA_STMT_EXPR: 4..7 
    LUA_MULTI_EXPR: 4..7 
      LUA_BINARY_EXPR: 4..7 
        LUA_LIT_EXPR: 4..5 
          INT: 4..5 "1"
        PLUS: 5..6 "+"
        LUA_LIT_EXPR: 6..7 
          INT: 6..7 "2"
  R_BRACE: 7..8 "}"
