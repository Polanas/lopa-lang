---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"|x,y: int| lua { #return x+y; }\", |p| p.expr())"
---
CLOSURE_EXPR: 0..31 
  CLOSURE_PARAM_LIST: 0..10 
    BAR: 0..1 "|"
    CLOSURE_PARAM: 1..3 
      NAME_PAT: 1..2 
        NAME: 1..2 
          IDENT: 1..2 "x"
      COMMA: 2..3 ","
    CLOSURE_PARAM: 3..9 
      NAME_PAT: 3..4 
        NAME: 3..4 
          IDENT: 3..4 "y"
      COLON: 4..5 ":"
      WHITESPACE: 5..6 
      LIT_TYPE: 6..9 
        LIT_TYPE_INT: 6..9 
          PATH_TYPE: 6..9 
            PATH: 6..9 
              PATH_SEGMENT: 6..9 
                IDENT: 6..9 "int"
    BAR: 9..10 "|"
  WHITESPACE: 10..11 
  LUA_CHUNK_EXPR: 11..31 
    LUA_KW: 11..14 "lua"
    WHITESPACE: 14..15 
    L_BRACE: 15..16 "{"
    WHITESPACE: 16..17 
    LUA_HASH_RETURN_STMT: 17..29 
      HASH: 17..18 "#"
      RETURN_KW: 18..24 "return"
      WHITESPACE: 24..25 
      LUA_MULTI_EXPR: 25..28 
        LUA_BINARY_EXPR: 25..28 
          LUA_LIT_EXPR: 25..26 
            IDENT: 25..26 "x"
          PLUS: 26..27 "+"
          LUA_LIT_EXPR: 27..28 
            IDENT: 27..28 "y"
      SEMI: 28..29 ";"
    WHITESPACE: 29..30 
    R_BRACE: 30..31 "}"
