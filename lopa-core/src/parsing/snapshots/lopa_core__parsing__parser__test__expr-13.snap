---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"|x,y: int| lua {x+y}\", |p| p.expr())"
---
CLOSURE_EXPR: 0..20 
  CLOSURE_PARAM_LIST: 0..11 
    BAR: 0..1 "|"
    CLOSURE_PARAM: 1..3 
      NAME_PATTERN: 1..2 
        NAME: 1..2 
          IDENT: 1..2 "x"
      COMMA: 2..3 ","
    CLOSURE_PARAM: 3..9 
      NAME_PATTERN: 3..4 
        NAME: 3..4 
          IDENT: 3..4 "y"
      COLON: 4..5 ":"
      WHITESPACE: 5..6 
      LIT_TYPE: 6..9 
        PATH: 6..9 
          IDENT: 6..9 "int"
    BAR: 9..10 "|"
    WHITESPACE: 10..11 
  LUA_BLOCK_EXPR: 11..20 
    LUA_KW: 11..14 "lua"
    WHITESPACE: 14..15 
    L_BRACE: 15..16 "{"
    LUA_STMT_EXPR: 16..19 
      LUA_MULTI_EXPR: 16..19 
        LUA_BINARY_EXPR: 16..19 
          LUA_LIT_EXPR: 16..17 
            IDENT: 16..17 "x"
          PLUS: 17..18 "+"
          LUA_LIT_EXPR: 18..19 
            IDENT: 18..19 "y"
    R_BRACE: 19..20 "}"
