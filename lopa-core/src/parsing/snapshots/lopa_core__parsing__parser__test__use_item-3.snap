---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"use root::test;\", |p| p.use_item())"
---
USE_ITEM: 0..15 
  USE_KW: 0..3 "use"
  WHITESPACE: 3..4 
  USE_ROOT_PATH: 4..14 
    ROOT_KW: 4..8 "root"
    COLON: 8..9 ":"
    COLON: 9..10 ":"
    USE_NAME: 10..14 
      NAME: 10..14 
        IDENT: 10..14 "test"
  SEMI: 14..15 ";"
