---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"1 + { 1 }\", |p| p.expr())"
---
BINARY_EXPR: 0..9
  LIT_EXPR: 0..2
    int: 0..1
    WHITESPACE: 1..2
  +: 2..3
  WHITESPACE: 3..4
  BLOCK_EXPR: 4..9
    {: 4..5
    WHITESPACE: 5..6
    EXPR_STMT: 6..8
      LIT_EXPR: 6..8
        int: 6..7
        WHITESPACE: 7..8
    }: 8..9
