---
source: lopa-core/src/parsing/parser.rs
expression: "parse(\"use foo::{bar,baz,*,self};\", |p| p.use_item())"
---
USE_ITEM: 0..26 
  USE_KW: 0..3 "use"
  WHITESPACE: 3..4 
  USE_PATH: 4..25 
    NAME: 4..7 
      IDENT: 4..7 "foo"
    COLON: 7..8 ":"
    COLON: 8..9 ":"
    USE_TREE_LIST: 9..25 
      L_BRACE: 9..10 "{"
      USE_NAME: 10..13 
        NAME: 10..13 
          IDENT: 10..13 "bar"
      COMMA: 13..14 ","
      USE_NAME: 14..17 
        NAME: 14..17 
          IDENT: 14..17 "baz"
      COMMA: 17..18 ","
      USE_GLOBAL: 18..19 
        STAR: 18..19 "*"
      COMMA: 19..20 ","
      USE_SELF: 20..24 
        SELF_KW: 20..24 "self"
      R_BRACE: 24..25 "}"
  SEMI: 25..26 ";"
